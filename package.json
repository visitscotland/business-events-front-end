{
  "name": "nuxt-app",
  "private": true,
  "scripts": {
    "build": "npm run lint:lockfile && nuxt build",
    "dev": "nuxt dev",
    "postinstall": "node -p \"require('./node_modules/@visitscotland/component-library/package.json').version\" > .clversion && nuxt prepare",
    "commit": "cz",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "lint": "eslint ./**/*.{js,vue,ts}",
    "lint:fix": "yarn lint --fix",
    "lint:lockfile": "lockfile-lint --path yarn.lock --type yarn --allowed-hosts yarn"
  },
  "lint-staged": {
    "*.{js,vue,ts}": "eslint"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "nuxt": "~3.21.2",
    "nuxt-lazy-hydrate": "^1.0.0"
  },
  "dependencies": {
    "@bloomreach/spa-sdk": "^23.4.4",
    "@bloomreach/vue3-sdk": "^22.0.5",
    "@pinia/nuxt": "^0.5.1",
    "@visitscotland/component-library": "5.59.3",
    "aws-rum-web": "2.0.0",
    "axios": "^1.16.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "express": "^5.2.1",
    "html-entities": "^2.6.0",
    "lint-staged": "^15.2.10",
    "lockfile-lint": "^5.0.0",
    "mitt": "^3.0.0",
    "nuxt-jsonld": "^2.0.8",
    "pinia": "^3.0.2",
    "sass": "^1.99.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.6.3"
  },
  "resolutions": {
    "vite": "^7.0.0"
  },
  "overrides": {
    "minimist": "latest",
    "@visitscotland/component-library": {
      "pinia": "^3.0.2",
      "vite": "^7.0.0"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "version": "0.0.24",
  "packageManager": "yarn@4.14.1"
}
